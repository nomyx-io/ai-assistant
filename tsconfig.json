{
    "compilerOptions": {
        "outDir": "dist",
        "moduleResolution": "node",
        "target": "es6",
        "module": "commonjs",
        "strict": true,
        "baseUrl": ".",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": false,
        "resolveJsonModule": true,
        "typeRoots": ["./node_modules/@types"]

    },
    "exclude": ["node_modules"],
    "include":["assistant/*", "tools/*"]
}